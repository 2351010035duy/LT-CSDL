@{
    ViewData["Title"] = "Home Page";
}
@model List<SalesApp.DTOs.ProductDTO>
<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="">
    </div>
    <!-- header section strats -->
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container ">
                <a class="navbar-brand" asp-controller="Home"
                       asp-action="Index">
                    <span>
                        AuraTech
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class=""> </span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav  mx-auto ">
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Home"
                                   asp-action="Index">
                                Home
                                <span class="sr-only">(current)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Category"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý Category
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Order" asp-action="Index" class="nav-link">
                                Quản lý đơn hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Customer"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý khách hàng
                            </a>
                        </li>
                    </ul>
                    
                </div>
            </nav>
        </div>
    </header>
    <!-- end header section -->
    
</div>


<!-- food section -->
<div class="container mt-3">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i>
            <strong>Lỗi:</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-check-circle me-2"></i>
            <strong>Thành công:</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>
<section class="food_section layout_padding-bottom">
    <div class="container">
        

        <div class="filters-content">
            <div class="row grid">     
                <div class="col-sm-6 col-lg-4 all burger">
                    <div class="box">
                        <div>
                            <div class="img-box">
                                <img src="https://tse3.mm.bing.net/th/id/OIP.C_S_JhWpU7LWnZIc2oHGGQAAAA?rs=1&pid=ImgDetMain&o=7&rm=3" alt="">
                            </div>
                            <div class="detail-box">
                                <h5>
                                    Kệ hàng trống
                                </h5>
                                <p>
                                    Thêm gì đó vào đây đi!
                                </p>
                                <div class="options">
                                    <h6>
                                        @((0 * 10_000).ToString("N0", new System.Globalization.CultureInfo("vi-VN")) + " VND")
                                    </h6>
                                        
                                </div>
                            </div>
                            <div class="btn-box" style="margin-bottom:10px">
                                <a asp-controller="Product"
                                       asp-action="Create">
                                    Thêm sản phẩm
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                @foreach (var p in Model)
                {
                    <div class="col-sm-6 col-lg-4 all burger">
                        <div class="box">
                            <div>
                                <div class="img-box">
                                    <img src="@p.ImageUrl" alt="">
                                </div>
                                <div class="detail-box">
                                    <h5>
                                        @p.Name
                                    </h5>
                                    <p>
                                        @p.Description
                                    </p>
                                    <div class="options">
                                        <h6>
                                            @((@p.Price * 10_000).ToString("N0", new System.Globalization.CultureInfo("vi-VN")) + " VND")
                                        </h6>
                                        
                                    </div>
                                </div>
                                <div class="btn-box" style="margin-bottom:10px">
                                    <a asp-controller="Product"
                                           asp-action="Index"
                                           asp-route-id="@p.ProductId">
                                        Sửa sản phẩm
                                    </a>
                                </div>
                                <form method="post" asp-action="Delete" asp-controller="Product" asp-route-id="@p.ProductId"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?');" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" style="padding:10px">Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>

                }
            </div>
        </div>
    </div>
</section>

<!-- end food section -->



