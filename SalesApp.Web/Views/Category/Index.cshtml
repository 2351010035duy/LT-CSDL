

@model List<SalesApp.DTOs.CategoryDTO>

<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="">
    </div>
    <!-- header section strats -->
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container ">
                <a class="navbar-brand" asp-controller="Home"
                       asp-action="Index">
                    <span>
                        AuraTech
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class=""> </span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav  mx-auto ">
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Home"
                                   asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Category"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý Category
                                <span class="sr-only">(current)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Order" asp-action="Index" class="nav-link">
                                Quản lý đơn hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Customer"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý khách hàng
                            </a>
                        </li>
                    </ul>
                    
                </div>
            </nav>
        </div>
    </header>
    <!-- end header section -->
    
</div>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Quản Lý Loại Sản Phẩm</h2>
            <p class="text-muted small mb-0">Danh sách các danh mục hàng hóa đang có trên hệ thống</p>
        </div>
        <a asp-controller="Category" asp-action="Create" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
            <i class="fa fa-plus me-2"></i> Thêm Category
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark text-uppercase fs-7" style="letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 15%">ID</th>
                            <th class="py-3" style="width: 55%">Tên loại danh mục</th>
                            <th class="text-center py-3 pe-4" style="width: 30%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@c.CategoryId</td>
                                    <td class="fw-semibold text-dark">@c.Name</td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-controller="Category"
                                                   asp-action="Edit"
                                                   asp-route-id="@c.CategoryId"
                                                   class="btn btn-sm btn-outline-dark fw-bold px-3">
                                                <i class="fa fa-edit me-1"></i> Sửa
                                            </a>
                                            <a asp-controller="Category"
                                                   asp-action="Delete"
                                                   asp-route-id="@c.CategoryId"
                                                   class="btn btn-sm btn-danger fw-bold px-3 shadow-sm"
                                                   onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?')">
                                                <i class="fa fa-trash me-1"></i> Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    <i class="fa fa-folder-open d-block fs-3 mb-2"></i>
                                    Chưa có loại sản phẩm nào được tạo.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
<!-- footer section -->
