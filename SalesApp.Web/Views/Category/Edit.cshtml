
@model SalesApp.DTOs.UpdateCategoryDTO
<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="">
    </div>
    <!-- header section strats -->
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container ">
                <a class="navbar-brand" asp-controller="Home"
                       asp-action="Index">
                    <span>
                        AuraTech
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class=""> </span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav  mx-auto ">
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Home"
                                   asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Category"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý Category
                                <span class="sr-only">(current)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Order" asp-action="Index" class="nav-link">
                                Quản lý đơn hàng
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Customer"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý khách hàng
                            </a>
                        </li>
                    </ul>
                    
                </div>
            </nav>
        </div>
    </header>
    <!-- end header section -->
    
</div>
<div class="container my-5" style="background-color:#222831; padding:20px; border-radius:20px">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            
            <div class="mb-3">
                <a asp-action="Index" class="text-decoration-none text-muted small">
                    <i class="fa fa-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>

            <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="card-title mb-0 text-center text-uppercase fw-bold text-white" style="letter-spacing: 0.5px;">
                        Cập Nhật Danh Mục
                    </h4>
                </div>
                
                <div class="card-body p-4 bg-light">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show small mb-3" role="alert">
                            <i class="fa fa-exclamation-circle me-1"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Edit" method="post">
                        
                        <input type="hidden" asp-for="CategoryId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Mã danh mục (ID)</label>
                            <input class="form-control bg-body-secondary text-dark fw-bold"
                                   value="@Model.CategoryId"
                                   readonly />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Tên loại danh mục</label>
                            <input asp-for="Name"
                                   class="form-control form-control-lg fs-6"
                                   placeholder="Nhập tên loại mới..."
                                   required />
                            <div class="form-text text-muted small">Thay đổi tên sẽ cập nhật tới toàn bộ sản phẩm thuộc loại này.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold text-white shadow-sm">
                                <i class="fa fa-save me-1"></i> Lưu thay đổi
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- footer section -->
