@model List<SalesApp.DTOs.OrderDTO>

@{
    ViewData["Title"] = "Danh sách đơn hàng";
}
<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="">
    </div>
    <!-- header section strats -->
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container ">
                <a class="navbar-brand" asp-controller="Home"
                       asp-action="Index">
                    <span>
                        AuraTech
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class=""> </span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav  mx-auto ">
                        <li class="nav-item active">
                            <a class="nav-link" asp-controller="Home"
                                   asp-action="Index">
                                Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Category"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý Category
                                
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Order" asp-action="Index" class="nav-link">
                                Quản lý đơn hàng
                                <span class="sr-only">(current)</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Customer"
                                   asp-action="Index"
                                   class="nav-link">
                                Quản lý khách hàng
                                
                            </a>
                        </li>
                    </ul>
                    
                </div>
            </nav>
        </div>
    </header>
    <!-- end header section -->
    
</div>
<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Quản Lý Đơn Hàng</h2>
            <p class="text-muted small mb-0">Theo dõi, kiểm tra và xử lý danh sách đơn hàng trên hệ thống</p>
        </div>
        <a asp-controller="Order" asp-action="Create" class="btn btn-success px-4 py-2 fw-bold shadow-sm">
            <i class="fa fa-plus-circle me-2"></i> Thêm đơn hàng
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark text-uppercase fs-7" style="letter-spacing: 0.5px;">
                        <tr>
                            <th class="ps-4 py-3" style="width: 10%">Mã ĐH</th>
                            <th class="py-3" style="width: 20%">Khách hàng</th>
                            <th class="py-3" style="width: 15%">Ngày đặt</th>
                            <th class="py-3" style="width: 15%">Tổng tiền</th>
                            <th class="py-3" style="width: 22%">Sản phẩm</th>
                            <th class="text-center py-3 pe-4" style="width: 18%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">#@item.OrderId</td>

                                    <td class="fw-semibold text-dark">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-user-circle text-muted me-2 fs-5"></i>
                                            @item.CustomerName
                                        </div>
                                    </td>

                                    <td class="text-secondary small">
                                        <i class="fa fa-calendar-alt text-muted me-1"></i>
                                        @item.OrderDate
                                    </td>

                                    <td class="fw-bold text-success">
                                        @((item.Total * 10_000).ToString("N0", new System.Globalization.CultureInfo("vi-VN")) + " đ")
                                    </td>

                                    <td>
                                        @if (item.Products != null && item.Products.Any())
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                @foreach (var prod in item.Products)
                                                {
                                                    <span class="badge bg-secondary bg-opacity-10 text-dark border border-secondary border-opacity-25 rounded-pill px-2 py-1 small fw-normal">
                                                        @prod
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted small italic">Không có sản phẩm</span>
                                        }
                                    </td>

                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-1">
                                            <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-info fw-bold" title="Xem chi tiết">
                                                <i class="fa fa-eye"></i>
                                            </a>
                                           
                                            <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-sm btn-danger shadow-sm" onclick="return confirm('Bạn có chắc muốn xóa đơn hàng này?')" title="Xóa đơn">
                                                <i class="fa fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fa fa-box-open d-block fs-2 mb-2 text-secondary"></i>
                                    Chưa có đơn hàng nào được ghi nhận.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
