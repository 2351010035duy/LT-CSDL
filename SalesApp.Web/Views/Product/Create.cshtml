

@model SalesApp.DTOs.CreateProductDTO

<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="">
    </div>
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container ">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span>AuraTech</span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class=""> </span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav mx-auto ">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item active">
                            <a asp-controller="Category" asp-action="Index" class="nav-link">Quản lý Category</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Order" asp-action="Index" class="nav-link">Quản lý đơn hàng</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Customer" asp-action="Index" class="nav-link">Quản lý khách hàng</a>
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </header>
</div>

<div class="container my-5" style="background-color:#222831; padding:20px; border-radius:20px">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="card-title mb-0 text-center text-uppercase fw-bold text-white" style="letter-spacing: 1px;">
                        Thêm Sản Phẩm Mới
                    </h4>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-action="Create" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Tên sản phẩm</label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Giá (VNĐ)</label>
                                <input asp-for="Price" class="form-control" type="number" placeholder="0" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold text-secondary">Số lượng</label>
                                <input asp-for="Stock" class="form-control" type="number" placeholder="0" />
                                <span asp-validation-for="Stock" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Mô tả sản phẩm</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">Link hình ảnh</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">Loại sản phẩm</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="0">-- Chọn loại sản phẩm --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold text-white shadow-sm">
                                <i class="fa fa-plus-circle me-2"></i> Lưu sản phẩm
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mt-2 text-center">
                                Quay lại danh sách
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
